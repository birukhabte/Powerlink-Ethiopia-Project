# Database Configuration - SUPABASE (Connection Pooler)
DB_HOST=your-supabase-host.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-database-password

# Alternative: Full connection string
DATABASE_URL=postgresql://postgres.your-project-ref:your-database-password@your-supabase-host.pooler.supabase.com:6543/postgres

# JWT Secret (generate a secure random string)
JWT_SECRET=your-jwt-secret-key-here

# Server Configuration
PORT=5000
NODE_ENV=development

# Super Admin Configuration
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=YourSecurePassword123!
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin

# Admin Configuration (for scripts)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecurePassword123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.vercel.app